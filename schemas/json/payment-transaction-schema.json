{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/fileflow/payment-transaction.json",
  "title": "Payment Transaction",
  "description": "Schema for validating payment transaction files",
  "type": "object",
  "required": ["header", "transactions"],
  "properties": {
    "header": {
      "type": "object",
      "required": ["batchId", "processingDate", "totalTransactions", "totalAmount"],
      "properties": {
        "batchId": {
          "type": "string",
          "pattern": "^BATCH_[0-9]{8}_[0-9]{6}$",
          "description": "Batch identifier in format BATCH_YYYYMMDD_HHMMSS"
        },
        "processingDate": {
          "type": "string",
          "format": "date",
          "description": "Processing date in YYYY-MM-DD format"
        },
        "totalTransactions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "Total number of transactions in this batch"
        },
        "totalAmount": {
          "type": "number",
          "multipleOf": 0.01,
          "minimum": 0,
          "description": "Total amount of all transactions"
        },
        "currency": {
          "type": "string",
          "enum": ["USD", "EUR", "GBP", "CAD", "AUD"],
          "default": "USD"
        }
      }
    },
    "transactions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "type": "object",
        "required": ["transactionId", "amount", "paymentMethod", "customerId", "timestamp"],
        "properties": {
          "transactionId": {
            "type": "string",
            "pattern": "^TXN_[A-Z0-9]{16}$",
            "description": "Unique transaction identifier"
          },
          "amount": {
            "type": "number",
            "multipleOf": 0.01,
            "minimum": 0.01,
            "maximum": 999999.99,
            "description": "Transaction amount"
          },
          "paymentMethod": {
            "type": "string",
            "enum": ["CREDIT_CARD", "DEBIT_CARD", "BANK_TRANSFER", "DIGITAL_WALLET", "CASH"],
            "description": "Payment method used"
          },
          "customerId": {
            "type": "string",
            "pattern": "^CUST_[0-9]{10}$",
            "description": "Customer identifier"
          },
          "merchantId": {
            "type": "string",
            "pattern": "^MERCH_[0-9]{8}$",
            "description": "Merchant identifier"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Transaction timestamp in ISO 8601 format"
          },
          "description": {
            "type": "string",
            "maxLength": 255,
            "description": "Transaction description"
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "COMPLETED", "FAILED", "CANCELLED"],
            "default": "PENDING"
          },
          "paymentDetails": {
            "type": "object",
            "properties": {
              "cardLast4": {
                "type": "string",
                "pattern": "^[0-9]{4}$",
                "description": "Last 4 digits of card (if applicable)"
              },
              "cardType": {
                "type": "string",
                "enum": ["VISA", "MASTERCARD", "AMEX", "DISCOVER"],
                "description": "Card type (if applicable)"
              },
              "authorizationCode": {
                "type": "string",
                "pattern": "^[A-Z0-9]{6,12}$",
                "description": "Authorization code"
              }
            }
          },
          "fees": {
            "type": "object",
            "properties": {
              "processingFee": {
                "type": "number",
                "multipleOf": 0.01,
                "minimum": 0
              },
              "networkFee": {
                "type": "number",
                "multipleOf": 0.01,
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "footer": {
      "type": "object",
      "properties": {
        "checksum": {
          "type": "string",
          "pattern": "^[A-F0-9]{64}$",
          "description": "SHA-256 checksum of transaction data"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "File generation timestamp"
        }
      }
    }
  }
}